{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/nicegui/static/tauri/tauri.conf.json",
  "productName": "Nyro",
  "version": "0.1.0",
  "identifier": "com.nyro.ai-gateway",
  "build": {
    "frontendDist": "../webui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../webui && pnpm dev",
    "beforeBuildCommand": "cd ../webui && pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Nyro AI Gateway",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
